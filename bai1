-- Tạo bảng
CREATE TABLE flights (
    flight_id SERIAL PRIMARY KEY,
    flight_name VARCHAR(100),
    available_seats INT
);

CREATE TABLE bookings (
    booking_id SERIAL PRIMARY KEY,
    customer_name VARCHAR(100),
    flight_id INT REFERENCES flights(flight_id)
);

-- Thêm dữ liệu mẫu
INSERT INTO flights (flight_name, available_seats)
VALUES ('Hanoi → Ho Chi Minh', 3),
       ('Hanoi → Da Nang', 2);

-- Transaction thành công
BEGIN;

UPDATE flights
SET available_seats = available_seats - 1
WHERE flight_id = 1;

INSERT INTO bookings (customer_name, flight_id)
VALUES ('Nguyen Van A', 1);

COMMIT;

-- Transaction lỗi và rollback
BEGIN;

UPDATE flights
SET available_seats = available_seats - 1
WHERE flight_id = 999;  -- flight_id không tồn tại

INSERT INTO bookings (customer_name, flight_id)
VALUES ('Nguyen Van B', 999);

ROLLBACK;

-- Kiểm tra dữ liệu
SELECT * FROM flights;
SELECT * FROM bookings;
